RewriteEngine On

# ---------------------------------------------------------------------------
# Keep non-production hosts out of search engines.
# Only the canonical production host (ethioware.org / www.ethioware.org) is
# indexable. Staging subdomains, preview hosts, and direct hostname/IP access
# get "X-Robots-Tag: noindex" so they can't be crawled or duplicate prod.
# The same file deploys everywhere — this is host-aware, so production is
# unaffected. (Combined with the canonical tags that point at ethioware.org.)
# ---------------------------------------------------------------------------
<IfModule mod_setenvif.c>
  SetEnvIfNoCase Host ^(www\.)?ethioware\.org$ is_production
</IfModule>
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow" env=!is_production
</IfModule>

# ---------------------------------------------------------------------------
# Canonical cleanup
# Strip a stray trailing "#" some shared links carry (e.g. /privacy# -> /privacy)
# ---------------------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/([^#\s]+)#  [NC]
RewriteRule ^ /%1 [R=301,L]

# ---------------------------------------------------------------------------
# Certificate / interview short URLs
#
# Learner certificates are published as:  https://ethioware.org/WI10092516
# The HTML lives in  certificates/  but the PUBLIC URL must never change, so
# this is an INTERNAL rewrite (no 3xx redirect): the address bar still shows
# /WI10092516 and the page's relative asset paths (assets/...) keep resolving
# against the site root.
#
# It fires only when the request is not a real file/dir AND a matching
# certificate exists on disk, so it automatically covers every code prefix
# (WI, MB, EB, ES, SEB, MEB, CMI, DI, RI, VI, MI, SI, WD, TS, LB, EM, SM, V...)
# now and for any future codes — no prefix list to maintain.
# ---------------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/certificates/$1.html -f
RewriteRule ^([A-Za-z0-9_-]+)(?:\.html)?$ certificates/$1.html [L]

# ---------------------------------------------------------------------------
# Extensionless pretty URLs for top-level pages
# /privacy -> privacy.html, /apply -> apply.html, etc.
# ---------------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# ---------------------------------------------------------------------------
# Compression — shrink text responses over the wire
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    text/javascript application/javascript application/json \
    image/svg+xml application/xml application/rss+xml
</IfModule>

# ---------------------------------------------------------------------------
# Browser caching — static assets are content-addressed by name, cache hard;
# HTML is kept fresh so page/certificate edits show up immediately.
# ---------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                       "access plus 1 week"
  ExpiresByType text/html              "access plus 0 seconds"
  ExpiresByType text/css               "access plus 1 month"
  ExpiresByType text/javascript        "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType image/x-icon           "access plus 1 year"
  ExpiresByType application/pdf        "access plus 1 month"
  ExpiresByType application/xml        "access plus 1 day"
</IfModule>

