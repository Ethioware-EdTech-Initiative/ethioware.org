RewriteEngine on

# Redirect short certificate URLs to Certificates/ directory
# Supports: /WIxxxx, /MBxxxx, /EBxxxx, /ESxxxx with or without .html
# Example: /WI10092516 -> /Certificates/WI10092516.html
#          /MB1023251.html -> /Certificates/MB1023251.html
RewriteCond %{REQUEST_URI} !^/Certificates/ [NC]
RewriteRule ^((WI|MB|EB|ES)[0-9A-Za-z_-]+)(?:\.html)?$ Certificates/$1.html [R=301,NC,L]

# Remove the trailing hash (#) from URLs
RewriteCond %{THE_REQUEST} \s/([^#\s]+)# [NC]
RewriteRule ^ %1 [R=301,L]

# Handle requests for directories and files in the current directory
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]