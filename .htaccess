RewriteEngine on

# Remove the trailing hash (#) from URLs
RewriteCond %{THE_REQUEST} \s/([^#\s]+)# [NC]
RewriteRule ^ %1 [R=301,L]

# Handle requests for directories and files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# Redirect certificate short URLs to Certificates/ directory
# Example: /WI10092516.html -> /Certificates/WI10092516.html
RewriteRule ^(WI[0-9A-Za-z_-]+)\.html$ Certificates/$1.html [R=301,NC,L]